# Supabase Frontend Credentials (Vite)
# These are exposed to the client-side application
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Edge Functions / CLI Credentials (Local Dev)
# Note: Service role key should NEVER be exposed to the frontend/client in production
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
